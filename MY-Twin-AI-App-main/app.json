{
  "expo": {
    "name": "MyTwin",
    "slug": "mytwin-ai",
    "scheme": "mytwin",
    "version": "5.3.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.soulsync.mytwin",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "يحتاج التطبيق للميكروفون للمحادثات الصوتية المباشرة.",
        "NSLocationWhenInUseUsageDescription": "يستخدم موقعك لتكييف تجربة التوأم الرقمي بناءً على الطقس والوقت من اليوم.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.soulsync.mytwin",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "RECORD_AUDIO",
        "VIBRATE",
        "ACCESS_FINE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      ["expo-build-properties", {
        "android": {
          "extraMavenRepos": [],
          "useFrameworks": "static",
          "enableProguardInReleaseBuilds": true
        }
      }],
      ["onesignal-expo-plugin", { "mode": "production" }],
      "expo-router",
      ["expo-av", {
        "microphonePermission": "يحتاج التطبيق للميكروفون للمحادثات الصوتية."
      }],
      ["expo-notifications", {
        "icon": "./assets/notification-icon.png",
        "color": "#5B4AE0"
      }],
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "router": { "origin": false },
      "eas": {
        "projectId": "0ed029b8-4ba3-4902-87ec-5c3505bfc4c6"
      }
    },
    "runtimeVersion": { "policy": "appVersion" },
    "updates": { "url": "https://u.expo.dev/0ed029b8-4ba3-4902-87ec-5c3505bfc4c6" },
    "owner": "soulsync.ai"
  }
}
